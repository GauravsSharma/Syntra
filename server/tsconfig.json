{
  "compilerOptions": {
    "module": "node16",
    "moduleResolution": "node16",    // Fixed: replaces deprecated "node"
    "ignoreDeprecations": "5.0",     // Optional safety net during migration
    "target": "ES2020",
    "outDir": "./dist",
    "rootDir": "./src",
    "esModuleInterop": true,
    "types": [],
    "sourceMap": true,
    "declaration": true,
    "declarationMap": true,
    "noUncheckedIndexedAccess": true,
    "exactOptionalPropertyTypes": true,
    "strict": true,
    "isolatedModules": true,
    "moduleDetection": "force",
    "skipLibCheck": true,
  }
}