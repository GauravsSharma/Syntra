{
  "compilerOptions": {
    "target": "ES2017",
    "lib": [
      "dom",
      "dom.iterable",
      "esnext"
    ],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": false,
    "noEmit": true,
    "incremental": true,
    "module": "node16",
    "esModuleInterop": true,
    "moduleResolution": "node16",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "ignoreDeprecations": "6.0",
    "jsx": "react-jsx",
    "baseUrl": ".",
    "paths": {
      "@/*": [
        "./*"
      ]
    },
    "plugins": [
      {
        "name": "next"
      }
    ]
  },
  "include": [
    "next-env.d.ts",
    ".next/types/**/*.ts",
    ".next/dev/types/**/*.ts",
    "**/*.mts",
    "**/*.ts",
    "**/*.tsx"
, "app/dashboard/page.jsx", "components/ui/button.jsx", "components/ui/dialog.jsx", "components/ui/input.jsx", "lib/utils.js", "components/conversation/MessageInput.jsx", "components/conversation/MessageBubble.jsx", "components/conversation/ConversationView.jsx", "components/conversation/ConversationSidebar.jsx", "components/conversation/ConversationHeader.jsx", "lib/data.js"  ],
  "exclude": [
    "node_modules"
  ]
}